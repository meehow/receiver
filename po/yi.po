msgid_plural "%d min ago"
msgstr[0] "%d מינוט צוריק"
msgstr[1] "%d מינוטן צוריק"

#: src/widgets/history_page.vala
#, c-format
msgid "%d hour ago"
msgid_plural "%d hours ago"
msgstr[0] "%d שעה צוריק"
