msgstr "Hemû encam berdest nînin"

#: src/services/song_downloader.vala
#, c-format
msgid "Downloading: %s"
msgstr "Tê daxistin: %s"

#. Clean up partial file
#: src/services/song_downloader.vala
msgid "Cancelled"
msgstr "Hat betalkirin"

#: src/services/song_downloader.vala
#, c-format
msgid "Download failed: %s"
msgstr "Daxistin neserkeft: %s"

#: src/services/song_downloader.vala
#, c-format
