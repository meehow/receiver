#: src/widgets/station_info_page.vala
msgid "Codec"
msgstr "Kodek"

#: src/widgets/station_info_page.vala
msgid "Bitrate"
msgstr "Rêjeya bit"

#: src/widgets/station_info_page.vala
msgid "Stream URL"
msgstr "URL-ya weşanê"

