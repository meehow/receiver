msgid_plural "%d min ago"
msgstr[0] "%d deq berê"
msgstr[1] "%d deq berê"

#: src/widgets/history_page.vala
#, c-format
msgid "%d hour ago"
msgid_plural "%d hours ago"
msgstr[0] "%d saet berê"
msgstr[1] "%d saet berê"

#: src/widgets/history_page.vala
#, c-format
