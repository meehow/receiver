msgid "Station"
msgstr "Stacioni"

#: src/widgets/station_info_page.vala
msgid "Country"
msgstr "Vendi"

#: src/widgets/station_info_page.vala
msgid "Tags"
msgstr "Etiketat"

#: src/widgets/station_info_page.vala
msgid "Website"
msgstr "Faqja e internetit"

#: src/widgets/station_info_page.vala
msgid "Codec"
