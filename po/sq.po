#: src/widgets/station_list.vala
msgid "Search stations…"
msgstr "Kërko stacione…"

#: src/widgets/station_list.vala
msgid "All Languages"
msgstr "Të gjitha gjuhët"

#: src/widgets/station_list.vala
msgid "Filter by language"
msgstr "Filtro sipas gjuhës"

