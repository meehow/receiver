#: src/widgets/station_info_page.vala:48
msgid "Station"
msgstr "Xitichi"

#: src/widgets/station_info_page.vala:52
msgid "Country"
msgstr "Tiko"

#: src/widgets/station_info_page.vala:56
msgid "Tags"
