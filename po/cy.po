msgstr "Ddim yn Chwarae"

#: src/widgets/player_bar.vala
msgid "Select a station"
msgstr "Dewiswch orsaf"

#: src/widgets/player_bar.vala
msgid "Buffering…"
msgstr "Yn byffro…"

#: src/widgets/player_bar.vala
msgid "Now playing"
msgstr "Yn chwarae nawr"

#: src/widgets/player_bar.vala
