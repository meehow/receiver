msgstr[2] "před %d hodinami"

#: src/widgets/history_page.vala
#, c-format
msgid "%d day ago"
msgid_plural "%d days ago"
msgstr[0] "před %d dnem"
msgstr[1] "před %d dny"
msgstr[2] "před %d dny"
