msgid "All Languages"
msgstr "Όλες οι γλώσσες"

#: src/widgets/station_list.vala
msgid "Filter by language"
msgstr "Φιλτράρισμα κατά γλώσσα"

#: src/widgets/station_list.vala
msgid "All Countries"
msgstr "Όλες οι χώρες"

#: src/widgets/station_list.vala
msgid "Filter by country"
msgstr "Φίλτρο ανά χώρα"

#: src/widgets/station_list.vala
msgid "No Stations"
msgstr "Δεν βρέθηκαν σταθμοί"

#: src/widgets/station_list.vala
msgid "Loading…"
msgstr "Φόρτωση…"

#: src/widgets/station_list.vala
#, c-format
