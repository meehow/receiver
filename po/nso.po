# Northern Sotho translation for receiver
msgid ""
msgstr ""
"Project-Id-Version: receiver\n"
"Report-Msgid-Bugs-To: \n"
"POT-Creation-Date: 2026-06-30 01:14+0200\n"
"Language: nso\n"
"MIME-Version: 1.0\n"
