msgid "Station"
msgstr "Stáisiún"

#: src/widgets/station_info_page.vala
msgid "Country"
msgstr "Tír"

#: src/widgets/station_info_page.vala
msgid "Tags"
msgstr "Clibeanna"

#: src/widgets/station_info_page.vala
msgid "Website"
msgstr "Suíomh gréasáin"

#: src/widgets/station_info_page.vala
msgid "Codec"
msgstr "Codec"

#: src/widgets/station_info_page.vala
msgid "Bitrate"
