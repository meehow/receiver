#: src/services/song_downloader.vala
#, c-format
msgid "Downloading: %s"
msgstr "ڈاؤنلوٗڈ بونٛ: %s"

#. Clean up partial file
#: src/services/song_downloader.vala
msgid "Cancelled"
msgstr "مَنسوٗخ"

#: src/services/song_downloader.vala
#, c-format
msgid "Download failed: %s"
msgstr "ڈاؤنلوٗڈ ناکام: %s"

#: src/services/song_downloader.vala
#, c-format
msgid "Saved: %s"
msgstr "محفوظ بیٖ: %s"

