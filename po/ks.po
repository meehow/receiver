msgid "Disconnect from Last.fm"
msgstr "Last.fm سٕتٕ ڈسکنیکٹ"

#: src/widgets/window.vala
msgid "Connect to Last.fm"
msgstr "Last.fm سٕتٕ کنیکٹ"

