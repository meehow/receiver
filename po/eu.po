#: src/widgets/station_list.vala
msgid "Search stations…"
msgstr "Bilatu irratiak…"

#: src/widgets/station_list.vala
msgid "All Languages"
msgstr "Hizkuntza guztiak"

#: src/widgets/station_list.vala
msgid "Filter by language"
msgstr "Iragazi hizkuntzaren arabera"

