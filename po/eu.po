#: src/widgets/station_info_page.vala
msgid "Tags"
msgstr "Etiketak"

#: src/widgets/station_info_page.vala
msgid "Website"
msgstr "Webgunea"

#: src/widgets/station_info_page.vala
msgid "Codec"
