#: src/widgets/station_info_page.vala
msgid "Station"
msgstr "Stacja"

#: src/widgets/station_info_page.vala
msgid "Country"
msgstr "Kraj"

#: src/widgets/station_info_page.vala
msgid "Tags"
msgstr "Tagi"

#: src/widgets/station_info_page.vala
msgid "Website"
msgstr "Strona internetowa"

#: src/widgets/station_info_page.vala
msgid "Codec"
msgstr "Kodek"

#: src/widgets/station_info_page.vala
msgid "Bitrate"
msgstr "Przepływność"

#: src/widgets/station_info_page.vala
msgid "Stream URL"
msgstr "URL strumienia"

#. Controls row
#: src/widgets/player_bar.vala
msgid "Not Playing"
msgstr "Nie odtwarza"

#: src/widgets/player_bar.vala
msgid "Play"
msgstr "Odtwórz"

#: src/widgets/player_bar.vala
msgid "Stop"
msgstr "Zatrzymaj"

#: src/widgets/player_bar.vala
msgid "Volume"
msgstr "Głośność"

#: src/widgets/player_bar.vala
msgid "Select a station"
msgstr "Wybierz stację"

#: src/widgets/player_bar.vala
msgid "Buffering…"
msgstr "Buforowanie…"

#: src/widgets/player_bar.vala
msgid "Now playing"
msgstr "Teraz gra"

#: src/widgets/player_bar.vala
msgid "Pause"
msgstr "Wstrzymaj"

#: src/widgets/player_bar.vala
msgid "Paused"
msgstr "Wstrzymano"

#: src/widgets/player_bar.vala
msgid "Reconnecting…"
msgstr "Ponowne łączenie…"

#. indeterminate while searching
#: src/services/song_downloader.vala
msgid "Searching YouTube…"
msgstr "Wyszukiwanie w YouTube…"

#: src/services/song_downloader.vala
#, c-format
msgid "Search failed: %s"
msgstr "Wyszukiwanie nie powiodło się: %s"

#: src/services/song_downloader.vala
msgid "No YouTube results found"
msgstr "Nie znaleziono wyników w YouTube"

#: src/services/song_downloader.vala
msgid "All results unavailable"
msgstr "Wszystkie wyniki niedostępne"

#: src/services/song_downloader.vala
#, c-format
msgid "Downloading: %s"
msgstr "Pobieranie: %s"

#. Clean up partial file
#: src/services/song_downloader.vala
msgid "Cancelled"
msgstr "Anulowano"

#: src/services/song_downloader.vala
#, c-format
msgid "Download failed: %s"
msgstr "Pobieranie nie powiodło się: %s"

#: src/services/song_downloader.vala
#, c-format
msgid "Saved: %s"
msgstr "Zapisano: %s"

#: src/widgets/download_button.vala
msgid "Download song"
msgstr "Pobierz utwór"

#: src/widgets/download_button.vala
msgid "Cancel download"
