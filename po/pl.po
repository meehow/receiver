#: src/widgets/history_page.vala
#, c-format
msgid "%d min ago"
msgid_plural "%d min ago"
msgstr[0] "%d min temu"
msgstr[1] "%d min temu"
msgstr[2] "%d min temu"

#: src/widgets/history_page.vala
#, c-format
msgid "%d hour ago"
msgid_plural "%d hours ago"
msgstr[0] "%d godzinę temu"
msgstr[1] "%d godziny temu"
msgstr[2] "%d godzin temu"

#: src/widgets/history_page.vala
#, c-format
msgid "%d day ago"
msgid_plural "%d days ago"
msgstr[0] "%d dzień temu"
msgstr[1] "%d dni temu"
msgstr[2] "%d dni temu"
