msgid "Disconnected from Last.fm"
msgstr "Dekonekte de Last.fm"

#: src/widgets/window.vala
msgid "Connecting to Last.fm…"
msgstr "Koneksyon ak Last.fm…"

#: src/widgets/window.vala
msgid "Failed to connect to Last.fm"
