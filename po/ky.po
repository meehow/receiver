#. Controls row
#: src/widgets/player_bar.vala
msgid "Not Playing"
msgstr "Ойнотулбайт"

#: src/widgets/player_bar.vala
msgid "Select a station"
msgstr "Станция тандаңыз"

#: src/widgets/player_bar.vala
msgid "Buffering…"
msgstr "Буферлөө…"

#: src/widgets/player_bar.vala
msgid "Now playing"
msgstr "Азыр ойнолууда"

#: src/widgets/player_bar.vala
msgid "Paused"
msgstr "Тыным"

#: src/widgets/player_bar.vala
msgid "Reconnecting…"
