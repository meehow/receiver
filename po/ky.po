#: src/services/song_downloader.vala
#, c-format
msgid "Downloading: %s"
msgstr "Жүктöлүүдö: %s"

#. Clean up partial file
#: src/services/song_downloader.vala
msgid "Cancelled"
msgstr "Жокко чыгарылды"

#: src/services/song_downloader.vala
#, c-format
msgid "Download failed: %s"
msgstr "Жүктöö ийгиликсиз: %s"

#: src/services/song_downloader.vala
#, c-format
msgid "Saved: %s"
msgstr "Сакталды: %s"

