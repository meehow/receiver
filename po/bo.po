#: src/application.vala
msgid "Receiver keeps playing radio after the window is closed"
msgstr "སྒེའུ་ཁུང་བརྒྱབ་རྗེས་སུའང་ Receiver ཡིས་རླུང་འཕྲིན་གཏོང་མུ་མཐུད་བྱེད།"

#: src/widgets/window.vala
msgid "Menu"
