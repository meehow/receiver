<?xml version="1.0" encoding="UTF-8"?>
<schemalist gettext-domain="receiver">
  <schema id="io.github.meehow.Receiver" path="/io/github/meehow/Receiver/">
    <key name="volume" type="d">
      <default>1.0</default>
      <summary>Playback volume</summary>
      <description>The playback volume level (0.0 to 1.0).</description>
    </key>
    <key name="last-station-id" type="x">
      <default>0</default>
      <summary>Last played station</summary>
      <description>The ID of the last played station, used to restore playback on startup.</description>
    </key>
    <key name="search-query" type="s">
      <default>''</default>
      <summary>Search query</summary>
      <description>The last search query entered by the user.</description>
    </key>
    <key name="language-filter" type="s">
      <default>'all'</default>
      <summary>Language filter</summary>
      <description>The language code used to filter the station list.</description>
    </key>
    <key name="country-filter" type="s">
      <default>'all'</default>
      <summary>Country filter</summary>
      <description>The country code used to filter the station list.</description>
    </key>
    <key name="download-dir" type="s">
      <default>''</default>
      <summary>Download directory</summary>
      <description>The last directory used to save downloaded songs.</description>
    </key>
    <key name="lastfm-session-key" type="s">
      <default>''</default>
      <summary>Last.fm session</summary>
      <description>Last.fm session key. Empty to disable scrobbling.</description>
    </key>
    <key name="lastfm-username" type="s">
      <default>''</default>
      <summary>Last.fm username</summary>
    </key>
    <key name="window-width" type="i">
      <default>580</default>
      <summary>Window width</summary>
    </key>
    <key name="window-height" type="i">
      <default>800</default>
      <summary>Window height</summary>
    </key>

  </schema>
</schemalist>
